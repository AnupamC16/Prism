PORT=:8080
LOG_LEVEL=info

REDIS_URL=redis://redis:6379/0

# JWT — minimum 32 characters
JWT_SECRET=change-me-to-something-secure-min-32-chars
TOKEN_TTL_SECONDS=3600

# Widevine
WIDEVINE_URL=https://widevine-license.example.com/license
WIDEVINE_API_KEY=your-widevine-api-key

# FairPlay
FAIRPLAY_URL=https://fairplay-license.example.com/license
FAIRPLAY_CERT_URL=https://fairplay-license.example.com/cert
FAIRPLAY_SECRET=your-fairplay-secret

# PlayReady
PLAYREADY_URL=https://playready-license.example.com/license

# CloudFront
CLOUDFRONT_DOMAIN=d123456789.cloudfront.net
CLOUDFRONT_KEY_PAIR_ID=APKAEXAMPLEKEYPAIRID
CLOUDFRONT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----
... PEM contents here ...
-----END RSA PRIVATE KEY-----"

# Cache TTLs (seconds)
MANIFEST_CACHE_TTL=30
LICENSE_CACHE_TTL=300
CERT_CACHE_TTL=3600

VERSION=1.0.0
